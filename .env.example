# Example environment variables for tutor_connect_project
# Copy to `.env` and fill with secure values for local development.

# Django secret key (set a unique, secret value for production)
SECRET_KEY=change-me

# DEBUG: True for local development, False for production
DEBUG=True

# Database (use DATABASE_URL or the default sqlite fallback)
DATABASE_URL=sqlite:///db.sqlite3

# Comma-separated allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,.herokuapp.com
